# ThreatWatch Environment Configuration
# Copy this to .env and fill in your values

# Flask
SECRET_KEY=
APP_ENV=development

# Network capture
CAPTURE_INTERFACE=eth0
MAX_PACKETS=10000

# Optional: VirusTotal API key for IP/domain reputation
# Leave blank to disable VirusTotal enrichment
VIRUSTOTAL_API_KEY=

# ML anomaly detection
# Fraction of flows expected to be anomalous (0.01 to 0.10)
ANOMALY_CONTAMINATION=0.05
